generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid()) @map("_id")
  email     String   @unique
  firstName String
  lastName  String
  password  String
  role      Role     @default(PORTFOLIO_MANAGER)
  avatar    String?
  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  ADMIN
  PORTFOLIO_MANAGER
  RESEARCH_ANALYST
  VIEWER
}

model Client {
  id              String   @id @default(cuid()) @map("_id")
  name            String
  broker          String
  accountNumber   String
  /// Free-text label kept for the existing CRUD UI. Analytics joins on benchmarkId
  /// instead: a string like "swderfg" cannot be joined to a price series.
  benchmark       String
  benchmarkId     String?
  riskProfile     RiskProfile

  /// Which cash flows feed this client's XIRR. See PerformanceService.
  ///
  /// CASH_FLOW    — the manager records the money the client actually handed over
  ///                and took back (CASH_DEPOSIT / CASH_WITHDRAWAL). Trades are
  ///                internal reshuffling and are NOT flows.
  /// TRANSACTIONAL — no external flow record exists; each BUY is treated as money
  ///                in and each SELL as money out, so the return is measured on
  ///                capital deployed into positions.
  ///
  /// The cash-flow method has been retired from the product: every client is now
  /// transactional. The enum value is kept so legacy records still read, but
  /// nothing writes CASH_FLOW anymore and the default for new rows is
  /// TRANSACTIONAL. See ClientsService, which forces this on every write.
  accountingMethod AccountingMethod @default(TRANSACTIONAL)

  /// Only meaningful under TRANSACTIONAL. Excluding fees gives the gross-of-fee
  /// return the manager is measured on; including them gives the net-of-fee
  /// return the client actually received. Both default ON, so the headline
  /// number is the one the client experienced.
  ///
  /// Under CASH_FLOW these are ignored — dividends and fees are already inside
  /// the terminal value there, because the cash landed in (or left) the balance.
  /// Counting them as flows as well would double-count them.
  includeDividends Boolean @default(true)
  includeFees      Boolean @default(true)

  currency        String   @default("USD")
  status          ClientStatus @default(ACTIVE)
  cashBalance     Float    @default(0)
  portfolioValue  Float    @default(0)
  xirr            Float    @default(0)
  notes           String?

  /// Annual management fee, as a percent (e.g. 2 for 2%). Billed quarterly at
  /// feeRatePercent / 4 of quarter-end portfolio value. Defaulted for clients
  /// created before this field existed; required on create going forward.
  feeRatePercent  Float    @default(0)
  /// The mandate's actual start date, used to prorate the first (partial)
  /// billing quarter. NOT the same as createdAt, which is only when the
  /// record was entered into Atlas PMS and may postdate real inception for
  /// backfilled clients. Defaults to createdAt's value at write time for
  /// clients created before this field existed.
  inceptionDate   DateTime @default(now())

  holdings        Holding[]
  transactions    Transaction[]
  research        Research[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([name])
  @@map("clients")
}

enum RiskProfile {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
}

enum AccountingMethod {
  TRANSACTIONAL
  CASH_FLOW
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

model Holding {
  id              String   @id @default(cuid()) @map("_id")
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  ticker          String
  company         String
  sector          String
  industry        String
  country         String
  theme           String?
  exchange        String

  quantity        Float
  averageCost     Float
  currentPrice    Float
  marketValue     Float
  allocationPercent Float @default(0)
  unrealizedPnL   Float @default(0)
  realizedPnL     Float @default(0)
  dividend        Float @default(0)
  weight          Float @default(0)
  targetWeight    Float @default(0)
  holdingDays     Int @default(0)

  investmentThesis String?
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([clientId, ticker])
  @@index([clientId])
  @@index([ticker])
  @@index([sector])
  @@map("holdings")
}

model Transaction {
  id              String   @id @default(cuid()) @map("_id")
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  ticker          String?
  type            TransactionType
  quantity        Float?
  price           Float?
  amount          Float
  date            DateTime
  description     String?
  reference       String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clientId])
  @@index([ticker])
  @@index([date])
  /// The valuation replay issues `clientId = ? AND date <= ?` once per client.
  /// Separate single-field indexes make Mongo pick one and scan the rest.
  @@index([clientId, date])
  @@map("transactions")
}

enum TransactionType {
  BUY
  SELL
  DIVIDEND
  SPLIT
  BONUS
  TRANSFER
  CASH_DEPOSIT
  CASH_WITHDRAWAL
  FEES
}

model Research {
  id              String   @id @default(cuid()) @map("_id")
  clientId        String?
  client          Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  ticker          String
  investmentThesis String?
  whyBought       String?
  catalysts       String?
  risks           String?
  valuation       String?
  targetAllocation Float?
  targetPrice     Float?
  reviewDate      DateTime?
  reviewNotes     String?
  attachments     String[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ticker])
  @@index([clientId])
  @@map("research")
}

/// A tracked ticker with no priority/status workflow — returns (MTD/QTD/YTD)
/// are computed live from market data, not stored here. `slot` is one of five
/// fixed lists ("1".."5") a ticker can be placed on; the same ticker may
/// appear on more than one list.
model Watchlist {
  id              String   @id @default(cuid()) @map("_id")
  slot            String   @default("1")
  ticker          String
  company         String
  sector          String
  industry        String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([slot, ticker])
  @@map("watchlists")
}

/// Display name for each of the five watchlist slots. Rows are created
/// lazily (upsert) the first time a slot's name is changed from its default.
model WatchlistFolder {
  id     String @id @default(cuid()) @map("_id")
  slot   String @unique
  name   String

  @@map("watchlist_folders")
}

// ─────────────────────────────────────────────────────────────────────────────
// Analytics engine — see ANALYTICS_ARCHITECTURE.md
// ─────────────────────────────────────────────────────────────────────────────

/// Daily bars for every instrument AND every benchmark. Benchmarks are ordinary
/// symbols (^GSPC, ^IXIC) rather than a separate table, so "beta vs the S&P" and
/// "beta vs a peer stock" are the same code path.
///
/// Without this collection there is no return series, and Beta/Sharpe/Sortino/
/// drawdown/attribution cannot be computed at all.
model PriceBar {
  id       String   @id @default(cuid()) @map("_id")
  symbol   String
  date     DateTime
  open     Float?
  high     Float?
  low      Float?
  close    Float
  /// Split- and dividend-adjusted. Returns are ALWAYS computed from this, never
  /// from `close` — using close makes every stock that paid a dividend look like
  /// it crashed on the ex-date.
  adjClose Float
  volume   Float?
  /// "yahoo" | "workbook" | "manual" — provenance stays auditable.
  source   String

  createdAt DateTime @default(now())

  /// Doubles as the range-scan index every risk calc issues, and as the idempotent
  /// upsert key that makes backfill safely re-runnable.
  @@unique([symbol, date])
  @@map("price_bars")
}

/// Named benchmarks. Client.benchmark is free text today (the live value is
/// literally "swderfg"), and free text cannot drive a calculation.
model Benchmark {
  id        String  @id @default(cuid()) @map("_id")
  code      String  @unique
  name      String
  /// Join key into PriceBar.symbol.
  symbol    String
  isDefault Boolean @default(false)

  @@map("benchmarks")
}

/// One row per instrument. Today sector/industry/country are copied onto every
/// holding row of every client, so reclassifying one ticker is an N-client write
/// and any partial failure leaves the house-level rollup inconsistent with itself.
model InstrumentProfile {
  id         String     @id @default(cuid()) @map("_id")
  symbol     String     @unique
  company    String
  assetClass AssetClass @default(EQUITY)
  sector     String     @default("Unclassified")
  industry   String     @default("Unclassified")
  /// Domicile of the ISSUER. For a US-listed China ETF this is "United States",
  /// which is exactly why lookThrough exists.
  country    String     @default("Unknown")
  region     String     @default("Unknown")
  exchange   String     @default("Unknown")
  currency   String     @default("USD")

  /// ETF decomposition: { region: [{ key: "China", weight: 1 }], sector: [...] }.
  /// Null for single stocks. Without this, a book holding MCHI reports 0% China
  /// exposure, because Yahoo classifies the fund itself as US-domiciled.
  lookThrough Json?

  source     String    @default("manual")
  /// Set when a human sets the classification. The nightly Yahoo sync must not
  /// overwrite a considered manual decision.
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sector])
  @@index([region])
  @@map("instrument_profiles")
}

enum AssetClass {
  EQUITY
  ETF
  FUND
  CASH_EQUIV
}

/// Daily NAV per client. PriceBar gives instrument history; this gives PORTFOLIO
/// history, which is what risk/drawdown/XIRR actually consume.
model PortfolioValuation {
  id              String   @id @default(cuid()) @map("_id")
  clientId        String
  date            DateTime

  securitiesValue Float
  cashValue       Float
  totalValue      Float

  /// EXTERNAL flows only (deposits/withdrawals). A BUY moves cash into securities
  /// inside the portfolio and leaves NAV unchanged — counting it here would
  /// double-count and corrupt the return.
  netFlow         Float    @default(0)

  /// Flow-adjusted: (V_t - V_{t-1} - F_t) / V_{t-1}. Stored rather than derived on
  /// read because every risk metric scans this column, and recomputing it needs
  /// that day's flows from another collection.
  dailyReturn     Float    @default(0)

  positionCount   Int      @default(0)
  /// Marks days where a price had to be carried forward. Stale days are excluded
  /// from volatility — a stale price makes risk read artificially LOW.
  stale           Boolean  @default(false)
  source          String   @default("eod-job")

  createdAt DateTime @default(now())

  @@unique([clientId, date])
  @@map("portfolio_valuations")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fundamentals Engine — see FUNDAMENTALS_ARCHITECTURE.md
//
// Three collections, one direction of dependency: FundamentalSnapshot (raw,
// provider-sourced) -> ScoringRule (operator-authored, provider-agnostic) ->
// FundamentalScore (derived, cached). Nothing here is read by any of the
// modules listed as already-existing (Holdings, Dashboard, Transactions,
// Performance, Reports, Live Prices, Portfolio Analytics) and nothing here
// reads from them either — the engine is additive.
// ─────────────────────────────────────────────────────────────────────────────

/// One symbol's raw fundamental data, as last fetched from the active provider.
/// This is the ONLY collection a provider adapter is allowed to write to —
/// everything downstream (scoring, industry comparison, explanations) reads
/// this shape and never touches the provider's response directly, which is
/// what makes swapping FMP for Finnhub/AlphaVantage/Polygon a provider-layer
/// change only.
model FundamentalSnapshot {
  id       String @id @default(cuid()) @map("_id")
  symbol   String @unique

  // ── Company information ────────────────────────────────────────────────
  company    String
  sector     String  @default("Unclassified")
  industry   String  @default("Unclassified")
  marketCap  Float?

  // ── Valuation ───────────────────────────────────────────────────────────
  peRatio          Float?
  forwardPe        Float?
  pegRatio         Float?
  evToEbitda       Float?
  priceToSales     Float?
  priceToBook      Float?
  enterpriseValue  Float?

  // ── Growth ──────────────────────────────────────────────────────────────
  revenueQoqPercent    Float?
  revenueYoyPercent    Float?
  netProfitQoqPercent  Float?
  netProfitYoyPercent  Float?
  revenueCagr3y        Float?
  netProfitCagr3y       Float?

  // ── Profitability ───────────────────────────────────────────────────────
  roe              Float?
  roic             Float?
  grossMargin      Float?
  operatingMargin  Float?
  netMargin        Float?

  // ── Financial strength ──────────────────────────────────────────────────
  debtToEquity      Float?
  currentRatio      Float?
  interestCoverage  Float?
  freeCashFlow      Float?

  // ── Momentum ────────────────────────────────────────────────────────────
  /// Average of the last up-to-4 quarters' (actual - estimated) / |estimated|,
  /// as a percent. Null when the provider has no estimate to compare against.
  lastFourEarningsBeatPercent  Float?
  nextEarningsDate             DateTime?
  /// Derived at read time from nextEarningsDate in the service layer, NOT
  /// stored — "days until" only means something relative to today, and
  /// storing it would go stale the moment a day passes without a refresh.

  // ── Dividend ────────────────────────────────────────────────────────────
  dividendYield      Float?
  dividendPerShare   Float?
  exDividendDate     DateTime?
  paymentDate        DateTime?

  /// "fmp" today; any adapter implementing FundamentalsProvider sets its own key.
  source     String   @default("fmp")
  refreshedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sector])
  @@index([industry])
  @@map("fundamental_snapshots")
}

/// One row = one banded rule for one metric under one strategy. The scoring
/// engine is ONLY this table plus a range lookup — there is deliberately no
/// switch/if-chain in code mapping a metric name to a score. Adding a new
/// factor, re-tuning a band, or authoring an entirely new strategy (Growth,
/// Value, Quality, Dividend, Small Cap, AI, ...) is a data change: insert
/// rows here, restart nothing, ship nothing.
///
/// A metric's rows within one strategy must tile the number line with no gaps
/// and no overlaps for the engine to always find exactly one match; the seed
/// data follows that convention but it is not (and cannot be) enforced by the
/// database schema itself, so treat it as a contract for anyone authoring rules.
model ScoringRule {
  id       String @id @default(cuid()) @map("_id")

  /// e.g. "Revenue YoY", "ROIC", "PE vs Industry" — must match the key the
  /// ScoringEngine looks up for that pillar's metric. See scoring-metrics.ts.
  metricName   String
  minimumValue Float
  maximumValue Float
  /// Points awarded [0..100] when the metric falls in [minimumValue, maximumValue).
  score        Float
  /// This metric's weight (points out of the pillar's total) under this strategy.
  /// Duplicated on every band row for the same metric+strategy by design —
  /// weight is a property of the METRIC, banding is a property of the VALUE,
  /// and keeping them on one row is what lets the engine compute
  /// `score/100 * weight` from a single matched record with no join.
  weight       Float
  /// "GARP" | "Growth" | "Value" | "Quality" | "Dividend" | "Small Cap" | "AI" | ...
  /// Free text on purpose: a brand-new strategy is rows with a new string here,
  /// never a schema migration or an enum change.
  strategy     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([strategy, metricName])
  @@map("scoring_rules")
}

/// One symbol's computed Atlas Fundamental Score under one strategy, cached so
/// the watchlist doesn't re-run five pillars' worth of rule lookups on every
/// render. Recomputed by the same daily refresh that pulls fresh snapshots,
/// and on demand if a caller asks for a symbol/strategy pair with no cache row.
model FundamentalScore {
  id       String @id @default(cuid()) @map("_id")
  symbol   String
  /// Matches ScoringRule.strategy — one symbol can be scored under several
  /// strategies at once (e.g. both "GARP" and "Growth") without collision.
  strategy String

  overallScore            Float
  growthScore              Float
  profitabilityScore       Float
  financialStrengthScore   Float
  valuationScore           Float
  momentumScore            Float

  /// Per-metric breakdown: [{ metric, value, matchedRange, score, weight,
  /// contribution, pillar }, ...]. This is what powers the "hover for full
  /// breakdown" requirement — the UI renders this directly rather than
  /// re-deriving it, so the tooltip can never disagree with the number
  /// next to it.
  breakdown  Json

  /// { strengths: string[], weaknesses: string[] } — see ExplanationEngine.
  explanation Json

  industryComparison Json?

  computedAt DateTime @default(now())

  @@unique([symbol, strategy])
  @@index([strategy, overallScore])
  @@map("fundamental_scores")
}

/// One row = one upcoming corporate event (earnings / dividend / split) as last
/// fetched from FMP's date-ranged calendars. The Event Center reads THIS, never
/// FMP directly, so the page keeps working when the FMP request budget is
/// exhausted or the process just restarted — same durability the Fundamentals
/// Engine gets from FundamentalSnapshot. A manual refresh (POST /events/refresh)
/// re-fetches the calendars and upserts these rows; nothing else writes here.
///
/// company / clientCount are deliberately NOT stored — they belong to Holding
/// and would drift the moment a position changes. The service joins them on at
/// read time. `ticker + type + date` is the natural key: FMP can list at most
/// one event of a given type per ticker per day.
model EventSnapshot {
  id     String @id @default(cuid()) @map("_id")
  ticker String
  /// "EARNINGS" | "DIVIDEND" | "SPLIT" — matches WatchlistEventType.
  type   String
  /// "E" | "D" | "C" badge code, carried through from the source event.
  code   String
  label  String
  /// ISO date (YYYY-MM-DD) the event falls on.
  date   String
  /// "Upcoming" | "Confirmed".
  status String

  source      String   @default("fmp")
  refreshedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ticker, type, date])
  @@index([ticker])
  @@map("event_snapshots")
}

/// Precomputed rollups. MongoDB has no GROUP BY across relations, so house-level
/// analytics are computed once by the nightly job rather than aggregated on every
/// read. This is the concession that makes 1000+ clients viable on Mongo; it costs
/// eventual consistency on house figures.
model AnalyticsCache {
  id         String   @id @default(cuid()) @map("_id")
  /// "house" | "client:<id>" | "overlap"
  scope      String
  metric     String
  asOf       DateTime
  payload    Json
  /// Fingerprint of the inputs, including a calcVersion that is bumped whenever a
  /// calculator's logic changes — otherwise a fixed formula keeps serving stale
  /// wrong numbers from cache, invisibly.
  inputHash  String

  computedAt DateTime @default(now())

  @@unique([scope, metric, asOf])
  @@index([scope, asOf])
  @@map("analytics_cache")
}
